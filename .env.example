# iMessage Pet Bot Configuration
# Copy to .env and fill in values

# 펫 메시지를 받을 전화번호 (+821012345678 형태)
RECIPIENT_PHONE=+8210XXXXXXXX

# Hook 서버 포트 (clawd-on-desk 23333과 충돌 방지)
SERVER_PORT=23456

# 로깅
LOG_LEVEL=INFO
LOG_DIR=./logs

# Rate Limiting
DAILY_MESSAGE_LIMIT=100
QUIET_HOURS_START=0
QUIET_HOURS_END=8

# 폴링 간격 (초)
POLLING_INTERVAL=2

# 테스트 모드 (true면 메시지 발송하지 않고 로그만)
DRY_RUN=false

# Permission Request (도구 사용 승인/거부)
PERMISSION_ENABLED=false        # true/false
PERMISSION_TIMEOUT=45           # 초 (0 = 무제한 대기)
PERMISSION_DEFAULT=allow        # allow 또는 deny (타임아웃 시 기본 동작)
